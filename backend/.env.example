# Google Gemini API key — get one at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API key — needed for Street View imagery and geocoding
# Enable: Street View Static API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Redis URL (used for caching — optional, defaults to localhost)
REDIS_URL=redis://localhost:6379

# Demo mode — when true, serves pre-computed results
DEMO_MODE=true

# Maximum bridges to scan per request
MAX_BRIDGES_PER_SCAN=50

# Directory for cached Street View images
STREETVIEW_CACHE_DIR=./data/demo_cache/images

# Gemini model to use
GEMINI_MODEL=gemini-3.1-flash-lite-preview
